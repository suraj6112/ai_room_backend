# File Processor Cloud Run Service - Environment Variables
#
# For local development, copy this to .env and fill in values
# For Cloud Run deployment, these are set via the deploy script

# High-Fidelity Extraction Settings
# (Increase these for dense financial tables, e.g., width=2500, quality=100)
EXTRACTION_MAX_WIDTH=1500
EXTRACTION_JPEG_QUALITY=85
MAX_PAGES_TO_PROCESS=100

# Tabular Review — text-only extraction (NOT vision)
# Used for the /extract and /extract-batch endpoints. The OpenAI key stays
# server-side; the browser NEVER calls OpenAI directly.
# See docs/design/TABULAR_REVIEW.md
EXTRACTION_MODEL=gpt-4o-mini
EXTRACTION_MAX_INPUT_CHARS=120000
EXTRACTION_BATCH_CONCURRENCY=10

# AI Provider Keys
OPENAI_API_KEY=sk-...

# Firebase programmatic credentials (instead of firebase-key.json)
FIREBASE_PROJECT_ID=<your-project-id>
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@<your-project-id>.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Cloud Project (for Firebase Admin SDK)
# Usually auto-detected on Cloud Run
GOOGLE_CLOUD_PROJECT=<your-project-id>

# Port (Cloud Run sets this automatically)
PORT=8080

# Temp directory for file processing
TEMP_DIR=/tmp/file-processor

# API key for authenticating requests from the API proxy
# Must match FILE_PROCESSOR_API_KEY in apiRequestProxy/.env
# Generate with: openssl rand -base64 32
FILE_PROCESSOR_API_KEY=

# Firebase Storage bucket (required)
# Usually: <your-project-id>.appspot.com or <your-project-id>.firebasestorage.app
FIREBASE_STORAGE_BUCKET=<your-project-id>.appspot.com

# Dev mode: enables CORS and skips auth so the frontend can call directly.
# Only use for local development — never in production.
DEV_MODE=true

# CloudFiles RAG (TypeSense doc cluster)
# Required for content search. After /process extracts a file, the file-
# processor chunks the markdown, calls OpenAI for embeddings, and upserts
# chunks into a per-tenant TypeSense collection. /search hits the same
# cluster. Leave blank to disable indexing/search (graceful no-op).
# @see docs/design/CONTENT_SEARCH.md
TYPESENSE_DOC_API_KEY=
TYPESENSE_DOC_HOST=
